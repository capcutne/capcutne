modules = ["web", "python-3.11", "postgresql-16"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"
integrations = ["python_openai_ai_integrations:1.0.0"]

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Setup API Key"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 auto_build.py && python3 -m http.server 5000 --bind 0.0.0.0"
waitForPort = 5000

[[workflows.workflow]]
name = "Setup API Key"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 setup_api_key.py"

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "static"
publicDir = "."
